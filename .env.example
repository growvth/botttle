# Used by `docker compose` in the repo root (variable substitution). Copy to `.env` and adjust.
# If you see "Bind for 0.0.0.0:5432 failed: port is already allocated", set a free port and use the
# same port in `apps/api/.env` → DATABASE_URL, e.g. postgresql://botttle:botttle@127.0.0.1:5433/botttle
POSTGRES_PUBLISH_PORT=5432
