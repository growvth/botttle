# Server
PORT=3001

# Database. If unset, the API uses SQLite at packages/db/prisma/dev.db (local dev).
# For production, set to your Postgres URL:
# DATABASE_URL="postgresql://user:password@localhost:5432/botttle?schema=public"

# Auth (use long random strings in production)
JWT_SECRET=your-jwt-secret-min-32-chars
REFRESH_SECRET=your-refresh-secret-min-32-chars
