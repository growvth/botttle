# Server
PORT=3001
# HOST=127.0.0.1

# Database (PostgreSQL). Start the DB with `docker compose up -d postgres` from the repo root, then:
DATABASE_URL="postgresql://botttle:botttle@127.0.0.1:5432/botttle"

# Optional: run `prisma migrate deploy` before the API starts (Docker image already does this in entrypoint-api.sh).
# RUN_MIGRATIONS_ON_BOOT=true

# Auth (use long random strings in production)
JWT_SECRET=your-jwt-secret-min-32-chars
REFRESH_SECRET=your-refresh-secret-min-32-chars

# Lemon Squeezy (optional): webhook signing secret from the Lemon dashboard
# LEMONSQUEEZY_WEBHOOK_SECRET=

# Optional: payment page URL for client portal "Pay online" on invoices with balance due.
# Use placeholders: {invoiceId} {amount} {amountCents} {currency}
# Example (adjust to your checkout): https://your-store.lemonsqueezy.com/checkout/buy/XXXX?checkout[custom][invoice_id]={invoiceId}
# INVOICE_PAYMENT_LINK_TEMPLATE=

# --- Async email (BullMQ + Redis + Resend) ---
# Start Redis: `docker compose up -d redis`
# Run worker (second terminal): `bun run dev:worker` from repo root, or use the `worker` service in Docker Compose.
# REDIS_URL=redis://127.0.0.1:6379
# RESEND_API_KEY=re_...
# EMAIL_FROM="botttle <notifications@yourdomain.com>"
# Links in emails (portal base URL)
# APP_PUBLIC_URL=http://localhost:5173

# --- Lemon Squeezy API (optional: server-generated checkout URLs) ---
# Create API key in Lemon dashboard. Variant id = numeric id from product variant URL in Lemon.
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_DEFAULT_VARIANT_ID=

# --- File storage: local (default) or S3-compatible ---
# FILE_STORAGE=local
# FILE_STORAGE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=your-bucket
# Optional (MinIO, R2 path-style):
# S3_ENDPOINT=https://...
