// Prisma schema for botttle.
// Phase 2: users, clients. Projects/milestones/tasks in Phase 4.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(CLIENT)
  name         String?
  disabled     Boolean   @default(false)
  clientId     String?   @map("client_id")
  client       Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  comments       Comment[]
  uploadedFiles  ProjectFile[] @relation("ProjectFileUploadedBy")
  notifications  Notification[]
  auditLogs      AuditLog[]
  passwordResets PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users    User[]
  projects Project[]

  @@map("clients")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?
  clientId    String        @map("client_id")
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status      ProjectStatus @default(DRAFT)
  progress    Int           @default(0)
  budget      Float?
  startDate   DateTime?     @map("start_date")
  endDate     DateTime?     @map("end_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  milestones Milestone[]
  invoices   Invoice[]
  timeLogs   TimeLog[]
  comments   Comment[]
  files      ProjectFile[]

  @@index([clientId])
  @@map("projects")
}

model Milestone {
  id                   String          @id @default(cuid())
  projectId            String          @map("project_id")
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title                String
  dueDate              DateTime?       @map("due_date")
  status               MilestoneStatus @default(PENDING)
  completionPercentage Int             @default(0) @map("completion_percentage")
  description          String?
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  tasks Task[]

  @@index([projectId])
  @@map("milestones")
}

model Task {
  id          String   @id @default(cuid())
  milestoneId String   @map("milestone_id")
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([milestoneId])
  @@map("tasks")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model Invoice {
  id             String        @id @default(cuid())
  projectId      String        @map("project_id")
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number         String        @unique
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime      @map("due_date")
  currency       String        @default("USD")
  taxRate        Float         @default(0) @map("tax_rate")
  subtotal       Float         @default(0)
  total          Float         @default(0)
  paymentUrl     String?       @map("payment_url")
  lemonVariantId String?       @map("lemon_variant_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  items    InvoiceItem[]
  payments Payment[]

  @@index([projectId])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String   @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @map("unit_price")
  amount      Float
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id         String        @id @default(cuid())
  invoiceId  String        @map("invoice_id")
  invoice    Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount     Float
  status     PaymentStatus @default(PENDING)
  paidAt     DateTime?     @map("paid_at")
  externalId String?       @map("external_id")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([invoiceId])
  @@map("payments")
}

model TimeLog {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description     String?
  startedAt       DateTime @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int      @default(0) @map("duration_seconds")
  billable        Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("time_logs")
}

model Comment {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("comments")
}

model ProjectFile {
  id              String               @id @default(cuid())
  projectId       String               @map("project_id")
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById    String               @map("uploaded_by_id")
  uploadedBy      User                 @relation("ProjectFileUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)
  filename        String
  mimeType        String?              @map("mime_type")
  size            Int
  storagePath     String               @map("storage_path")
  storageProvider FileStorageProvider  @default(LOCAL) @map("storage_provider")
  createdAt       DateTime             @default(now()) @map("created_at")

  @@index([projectId])
  @@map("project_files")
}

enum NotificationKind {
  COMMENT
  FILE_UPLOAD
}

enum FileStorageProvider {
  LOCAL
  S3
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotificationKind
  title     String
  body      String?
  linkHref  String?          @map("link_href")
  projectId String?         @map("project_id")
  readAt    DateTime?       @map("read_at")
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("notifications")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?  @map("actor_user_id")
  actor        User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action       String
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  metadata     Json?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_logs")
}
