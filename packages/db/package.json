{
  "name": "@botttle/db",
  "version": "0.0.1",
  "private": true,
  "description": "Prisma schema and database client for botttle",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "prisma"],
  "scripts": {
    "build": "bun run generate && tsc",
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "prisma": "^6.1.0",
    "typescript": "^5.6.3"
  }
}
